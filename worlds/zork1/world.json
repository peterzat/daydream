      "steal_filter": {
        "key": "treasure",
        "eq": true
      },
      "deposit_room": "r-treasure-room",
      "arrive_text": "A seedy-looking gentleman with a large bag slips in, giving you a nod that manages to be both courteous and appraising.",
      "leave_text": "The seedy-looking gentleman ducks away into the dark, bag first.",
      "steal_room_text": "A quick shadow crosses the room; something that was there is not.",
      "steal_text": "You feel a light finger's touch at your satchel, and a moment later the seedy-looking gentleman is elsewhere and slightly richer.",
      "active": true
    },
    "swordglow": {
      "kind": "glow",
      "item": "o-sword",
      "hostiles": [
        "t-troll",
        "t-thief",
        "t-cyclops"
      ],
      "bright_text": "Your sword has begun to glow very brightly.",
      "faint_text": "Your sword is glowing with a faint blue glow.",
      "dim_text": "Your sword is no longer glowing.",
      "active": true
    },
    "river": {
      "kind": "conveyor",
      "vehicle": "o-boat",
      "path": [
        "r-river-1",
        "r-river-2",
        "r-river-3",
        "r-river-4",
        "r-river-5"
      ],
      "delays": [
        4,
        4,
        3,
        2
      ],
      "carry_text": "The current takes the little boat and carries it on downriver.",
      "active": true
    },
    "map-reveal": {
      "kind": "script",
      "once": true,
      "if": [
        {
          "score": {
            "gte": 350
          }
        }
      ],
      "do": [
        {
          "kind": "set_flag",
          "name": "WON-ENABLED",
          "value": true
        },
        {
          "kind": "spawn_object",
          "name": "ancient map",
          "location_id": "o-trophy-case",
          "seed": "a parchment map of the land surrounding the white house, marked with one path that was never there before",
          "generated_by": "world:won",
          "aliases": [
            "map",
            "parchment"
          ]
        },
        {
          "kind": "narrate",
          "room": "r-living-room",
          "text": "Inside the trophy case, where there was nothing left to want, an ancient parchment map has quietly appeared."
        }
      ],
      "active": true
    }
  },
  "rules": [
