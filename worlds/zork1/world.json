  "fuses": {
    "bell-window": {
      "turns": 6,
      "do": [
        {
          "kind": "set_flag",
          "name": "BELL-RUNG",
          "value": false
        }
      ]
    },
    "candle-window": {
      "turns": 3,
      "do": [
        {
          "kind": "set_flag",
          "name": "CANDLES-RITUAL",
          "value": false
        }
      ]
    },
    "bell-cool": {
      "turns": 20,
      "do": [
        {
          "kind": "set_property",
          "target_id": "o-bell",
          "key": "state",
          "value": "normal"
        }
      ]
    },
    "reservoir-drain": {
      "turns": 8,
      "do": [
        {
          "kind": "set_flag",
          "name": "LOW-TIDE",
          "value": true
        },
        {
          "kind": "move_object",
          "object_id": "o-trunk",
          "dest_id": "r-reservoir"
        },
        {
          "kind": "narrate",
          "room": "r-reservoir-south",
          "text": "The water level behind the dam falls away with a long, diminishing sigh; the reservoir gives up its bed."
        }
      ]
    },
    "reservoir-fill": {
      "turns": 8,
      "do": [
        {
          "kind": "set_flag",
          "name": "LOW-TIDE",
          "value": false
        },
        {
          "kind": "narrate",
          "room": "r-reservoir-south",
          "text": "The water climbs back up its old marks behind the dam; the reservoir remembers itself."
        }
      ]
    },
    "maint-flood": {
      "turns": 12,
      "do": [
        {
          "kind": "set_flag",
          "name": "MAINT-FLOODED",
          "value": true
        },
        {
          "kind": "narrate",
          "room": "r-maintenance-room",
          "text": "The water reaches the ceiling pipes. The maintenance room is a maintenance pond now."
        }
      ]
    }
  },
  "daemons": {
    "thief": {
      "kind": "wanderer",
      "toon": "t-thief",
      "rooms": [
        "r-round-room",
        "r-ew-passage",
        "r-narrow-passage",
