{
  "format": 2,
  "world": {
    "name": "Zork I: The Great Underground Empire",
    "slug": "zork1",
    "aesthetic_seed": "a watercolor Great Underground Empire: white clapboard house at the wood's edge, lantern-lit stone passages, cold green river water, brass and dust and old imperial grandeur gone soft at the edges",
    "rng_seed": "zork1-release-88"
  },
  "start_room": "r-west-of-house",
  "config": {
    "carry_capacity": 100,
    "darkness": {
      "text": "It is pitch black. You are likely to be eaten by a grue.",
      "hazard_chance": 0.8,
      "hazard_text": "Oh, no! You have walked into the slavering fangs of a lurking grue!"
    },
    "death": {
      "penalty": 10,
      "respawn_room": "r-forest-1",
      "messages": [
        "You have died. The world goes quiet for a moment, and then you are among trees, with the smell of earth and the certainty that this has cost you.",
        "You have died again. The forest takes you back without comment, though you sense its patience is not a compliment.",
        "You have died once more. At this rate the forest floor will learn the shape of you."
      ],
      "scatter": {
        "special": {
          "o-lamp": "r-living-room",
          "o-coffin": "r-egypt-room"
        },
        "filters": [
          {
            "key": "treasure",
            "eq": true,
            "rooms": [
              "r-troll-room",
              "r-gallery",
              "r-round-room",
              "r-loud-room",
              "r-damp-cave",
              "r-mine-entrance",
              "r-cold-passage"
            ]
          }
        ],
        "default_rooms": [
          "r-west-of-house",
          "r-north-of-house",
          "r-south-of-house",
          "r-behind-house",
          "r-forest-2",
          "r-forest-path",
          "r-clearing"
        ]
      },
      "set_flags": {
        "TRAP-DOOR-OPEN": false
      },
      "stop_fuses": [
        "bell-window",
        "candle-window"
      ]
    }
  },
  "voice": {
    "register": "Dry, precise, unhurried; wit by understatement, never exclamation. Rooms are reported like a surveyor's notes with one flourish allowed. The world is old, imperial, and indifferent to you.",
    "examples": [
      "You are standing in an open field west of a white house, with a boarded front door.",
      "This is a forest, with trees in all directions. To the east, there appears to be sunlight.",
      "A chasm runs southwest to northeast and the path follows it. You are on the south side."
    ],
    "parser_hints": [
      "douse means extinguish",
      "get means take",
      "smash/whack a foe means attack it with the carried weapon"
    ],
    "retell": {
      "enabled": true,
      "banlist": [
        "cozy",
        "whimsical",
        "magical",
        "adorable"
      ],
      "max_ratio": 1.6
    }
  },
  "scoring": {
    "ranks": [
      {
        "min": 0,
        "name": "Beginner"
      },
      {
        "min": 25,
        "name": "Amateur Adventurer"
      },
      {
        "min": 50,
        "name": "Novice Adventurer"
      },
      {
        "min": 100,
        "name": "Junior Adventurer"
      },
      {
        "min": 200,
