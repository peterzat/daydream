# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# SQLite (canonical state lives under ~/data/daydream/, never in tree)
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Frontend build
web/dist/
web/node_modules/

# Local config (secrets sourced from ~/.config/daydream/secrets.env)
.env
.env.local

# IDE / editor
.vscode/
.idea/
*.swp
.DS_Store

# Per-project Claude state
.claude/

# External engines (ComfyUI, vLLM, etc.) — cloned + populated by bin/<engine>-bootstrap.
# Project tree stays self-contained on disk but git-light. Re-bootstrap is cheap.
external/

# Drift baselines: *.golden.json is git-tracked (the contract); *.latest.json
# is written on every `bin/game test long` run as the observation to review
# before ratifying a new golden. See TESTING.md "The drift loop".
tests/baselines/*.latest.json

# Original design prompt — local-only working copy (lives under docs/history/).
docs/history/ORIGINAL-PROMPT.md
