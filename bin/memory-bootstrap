#!/usr/bin/env bash
# bin/memory-bootstrap — one-time, idempotent installer for the NPC memory
# subsystem. Installs sentence-transformers (CPU-only torch) into daydream's
# main .venv and pre-caches the BGE-small embedder into the shared HF cache
# (~/.cache/huggingface; never override HF_HOME per zat.env convention).
#
# Why CPU-only torch:
# - The embedder runs on CPU by construction (daydream/memories.py sets
#   device='cpu' explicitly). The 20 GB GPU is reserved for vLLM + ComfyUI
#   under the arbiter; embedding alongside them buys nothing.
# - Default torch wheels carry ~1.5 GB of CUDA libs we never use. The
#   PyTorch CPU wheel index drops that to ~200 MB.
#
# Re-running this is a no-op when both the package and the model cache are
# already in place. After this completes, the dialogue path picks up the
# embedder lazily on the next NPC exchange — no daemon to launch.
#
# Memory subsystem behavior with this script NOT run:
# - capture / retrieve fail closed and log a warning. Dialogue still
#   works; NPCs just have no memory. So bin/memory-bootstrap is a quality
#   upgrade, not a hard prerequisite for bin/game up.

set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VENV_PY="$PROJECT_ROOT/.venv/bin/python"
MODEL="${DAYDREAM_MEMORY_MODEL:-BAAI/bge-small-en-v1.5}"
TORCH_INDEX="${DAYDREAM_TORCH_CPU_INDEX:-https://download.pytorch.org/whl/cpu}"

if [[ ! -x "$VENV_PY" ]]; then
    echo "Daydream venv not found at $PROJECT_ROOT/.venv. Bootstrap that first." >&2
    exit 1
fi

echo "==> sentence-transformers (CPU-only torch)"
if "$VENV_PY" -c "import sentence_transformers" 2>/dev/null; then
    echo "    already installed"
else
    echo "    installing via $TORCH_INDEX ..."
    "$VENV_PY" -m pip install --quiet \
        --extra-index-url "$TORCH_INDEX" \
        sentence-transformers
fi

echo "==> Model: $MODEL"
"$VENV_PY" - <<PY
from huggingface_hub import snapshot_download
import os, sys
try:
    p = snapshot_download("$MODEL")
    sz = sum(os.path.getsize(os.path.join(d, f))
             for d, _, fs in os.walk(p) for f in fs)
    print(f"    cached at {p} ({sz/1_000_000:.0f} MB)")
except Exception as e:
    print(f"    download failed: {e}", file=sys.stderr)
    sys.exit(1)
PY

echo
echo "Memory bootstrap complete. NPCs pick up the embedder on the next dialogue exchange."
