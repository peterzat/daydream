# Copy to .env (gitignored) and fill in. bin/game sources .env at startup.
# Anything set here is overridable by ~/.config/daydream/secrets.env (per-host).

# Shared site password. The auth endpoint refuses every login (503) when this
# is unset or empty, so running with no .env at all is a fail-closed state.
DAYDREAM_PASSWORD=

# Session-cookie signing secret. If unset, bin/game / the server generates a
# per-install random secret on first boot and persists it under
# ~/.config/daydream/session_secret (mode 0600). Setting it here pins the value.
# DAYDREAM_SESSION_SECRET=

# Optional: pin the bind port (default 8080).
# DAYDREAM_PORT=8080

# Optional: pin the env name (default dev). Multi-env layout lands in v2.
# DAYDREAM_ENV=dev

# Optional: vLLM endpoint config (defaults are http://localhost:8000/v1 and
# Qwen 2.5 7B Instruct via litellm's hosted_vllm/ prefix).
# DAYDREAM_LLM_BASE_URL=http://localhost:8000/v1
# DAYDREAM_LLM_MODEL=hosted_vllm/Qwen/Qwen2.5-7B-Instruct
