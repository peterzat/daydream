# Copy to .env (gitignored) and fill in. bin/game sources .env at startup.
# Anything set here is overridable by ~/.config/daydream/secrets.env (per-host).

# Shared site password. The auth endpoint refuses every login (503) when this
# is unset or empty, so running with no .env at all is a fail-closed state.
DAYDREAM_PASSWORD=

# Network access mode. 'tailscale' (default) lets the AccessMiddleware reject
# any client whose source IP is not in 100.64.0.0/10 (Tailscale CGNAT) or
# loopback. 'public' lets all clients through.
#
# IMPORTANT: setting this to 'public' does NOT also open UFW. The toggle is
# an "agree to be public" flag at the app layer; for traffic to actually
# arrive from the internet you also need:
#   sudo ufw allow ${DAYDREAM_PORT:-54321}/tcp
# and a public DNS pointing at this box's external IP.
DAYDREAM_ACCESS=tailscale

# Session-cookie signing secret. If unset, bin/game / the server generates a
# per-install random secret on first boot and persists it under
# ~/.config/daydream/session_secret (mode 0600). Setting it here pins the value.
# DAYDREAM_SESSION_SECRET=

# Optional: pin the bind port (default 54321 — memorable, non-default for
# modest security-by-obscurity on a user-visible service).
# DAYDREAM_PORT=54321

# Optional: pin the env name (default dev). Multi-env layout lands in v2.
# DAYDREAM_ENV=dev

# Optional: vLLM endpoint and bind. Daydream is the only consumer, so vLLM
# binds 127.0.0.1 by default — set DAYDREAM_VLLM_HOST=0.0.0.0 to expose it
# on the tailnet (e.g., for an external monitoring tool).
# DAYDREAM_LLM_BASE_URL=http://localhost:8000/v1
# DAYDREAM_LLM_MODEL=hosted_vllm/Qwen/Qwen2.5-7B-Instruct-AWQ
# DAYDREAM_VLLM_HOST=127.0.0.1
# DAYDREAM_VLLM_PORT=8000

# Optional: ComfyUI endpoint and bind. Same default rationale; set
# DAYDREAM_COMFYUI_HOST=0.0.0.0 if you want the ComfyUI web UI reachable
# from another tailnet machine (otherwise tunnel via ssh -L 8188:localhost:8188).
# DAYDREAM_COMFYUI_BASE_URL=http://localhost:8188
# DAYDREAM_COMFYUI_HOST=127.0.0.1
# DAYDREAM_COMFYUI_PORT=8188
